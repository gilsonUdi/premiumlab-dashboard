# Copie este arquivo para .env.local e preencha no computador do cliente.

# -- Firebird ---------------------------------------------------------------
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:\CAMINHO\BANCO.FDB
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# -- Upstash Redis REST -----------------------------------------------------
# Copiar no painel do Upstash: REST URL e REST Token.
UPSTASH_REDIS_REST_URL=https://seu-banco.upstash.io
UPSTASH_REDIS_REST_TOKEN=seu-token

# Prefixo usado nas chaves do Redis. Use um prefixo por cliente/empresa.
UPSTASH_KEY_PREFIX=premium:premium-lab

# -- Tabelas sincronizadas --------------------------------------------------
SYNC_TABLES=BANCO,CLIEN,PRODU,FUNCIO,ALMOX,CFOP,CIDADE,CCORR,PAGAR,RECEB,MOVIMENTACAO,PEDFINALIDADE,GRUPOCLI,GRUPOROTULOS,LOCALPED,REQUI,PEDFO,NOTAS,PEDID,PDPRD,PDSER,TBFIS,COMPOPROROT,REGRAPROMO,USUARIO,ACOPED

# Filtros para tabelas grandes/transacionais.
# Formato: TABELA:COLUNA,TABELA2:COLUNA2
SYNC_DATE_COLUMNS=CCORR:CCODATA,PAGAR:PAGDTVENCTO,RECEB:RECDTVENCTO,MOVIMENTACAO:DATA,REQUI:REQDATA,PEDFO:PEFDTBAIXA,NOTAS:NFDTEMIS,PEDID:PEDDTEMIS,ACOPED:APDATA
SYNC_DATE_FROM=2025-04-23

# Depois da primeira carga, use janela movel para sincronizar somente registros recentes.
# Com SYNC_MERGE_MODE=true, esses registros sao atualizados sem apagar historico antigo.
SYNC_RECENT_DAYS=3
SYNC_MERGE_MODE=true
SYNC_INDEX_COLUMNS=ACOPED:id_pedido,PDPRD:id_pedido,PDSER:id_pedido,REQUI:pdccodigo

# Para a rotina agendada, sincronize somente as tabelas listadas em SYNC_DATE_COLUMNS.
# Para carga completa manual, sobrescreva no PowerShell:
# $env:SYNC_DATE_TABLES_ONLY="false"
SYNC_DATE_TABLES_ONLY=true

# -- Performance ------------------------------------------------------------
SYNC_FETCH_BATCH=1000
SYNC_CHUNK_ROWS=1000
SYNC_BUCKET_COUNT=64
SYNC_INTERVAL_SECONDS=300
SYNC_LOG_DIR=logs
