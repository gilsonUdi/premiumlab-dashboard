# Copie este arquivo para .env.local e preencha no computador do cliente.

# -- Firebird ---------------------------------------------------------------
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:\CAMINHO\BANCO.FDB
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# -- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# Use o Session Pooler do Supabase (porta 5432) para o rebuild pesado dos caches.
# Evite o host direto "db.<project-ref>.supabase.co" nesta rotina, pois ele ficou
# mais sujeito a timeout durante os rebuilds de cache.
SUPABASE_DATABASE_URL=postgresql://postgres.xxx:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# -- Tabelas usadas pela Analise de Dados e PPS -----------------------------
SYNC_TABLES=CLIEN,FUNCIO,ALMOX,LOCALPED,USUARIO,REQUI,PEDID,PDPRD,PDSER,ACOPED,PEDFINALIDADE,JBXROTEIRO,ENDCLI,ZONA
# ROTULOSCLIEN, GRUPOCLI, ENDCLI e ZONA entram automaticamente no sync para manter as relacoes
# auxiliares da CLIENCRM e dos grupos de cliente.
# Tabelas derivadas manuais maiores, como CLIENCRM, continuam sob demanda:
# node sync.js --table CLIENCRM
# Rebuild somente dos caches, sem sincronizar tabelas:
# node sync.js --cache-only
# node sync.js --cache-only dashboard
# node sync.js --cache-only roteiro --cache-from-date 2026-02-06

# -- Filtros para tabelas grandes/transacionais -----------------------------
SYNC_DATE_COLUMNS=REQUI:REQDATA,PEDID:PEDDTEMIS,ACOPED:APDATA
SYNC_LINKED_DATE_TABLES=PDPRD:ID_PEDIDO:PEDID:PEDDTEMIS:90,PDSER:ID_PEDIDO:PEDID:PEDDTEMIS:90,JBXROTEIRO:ID_PEDIDO:ACOPED:APDATA:90
SYNC_REFRESH_LINKED_TABLES=JBXROTEIRO:ID_PEDIDO:ACOPED:APDATA:90
SYNC_UPSERT_TABLES=REQUI,PEDID,ACOPED,PDPRD,PDSER,JBXROTEIRO
SYNC_INCREMENTAL=true
SYNC_DATE_FROM=2025-04-23
SYNC_RECENT_DAYS=90
SYNC_DATE_TABLES_ONLY=true

# -- Performance ------------------------------------------------------------
# Tabelas recentes e vinculadas a pedidos recentes sao recarregadas por janela.
# Tabelas restantes continuam em modo insert-only.
SYNC_FETCH_BATCH=1000
SYNC_INSERT_BATCH=500
SYNC_HEAVY_TABLES=ACOPED,PDPRD,PEDID,REQUI
SYNC_HEAVY_FETCH_BATCH=100
SYNC_HEAVY_INSERT_BATCH=50
SYNC_HEAVY_WINDOW_DAYS=7
SYNC_INTERVAL_SECONDS=600
SYNC_LOG_DIR=logs
