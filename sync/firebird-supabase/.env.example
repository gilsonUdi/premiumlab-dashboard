# Copie este arquivo para .env.local e preencha no computador do cliente.

# -- Firebird ---------------------------------------------------------------
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:\CAMINHO\BANCO.FDB
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# -- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# -- Tabelas sincronizadas --------------------------------------------------
SYNC_TABLES=BANCO,CLIEN,PRODU,FUNCIO,ALMOX,CFOP,CIDADE,CCORR,PAGAR,RECEB,MOVIMENTACAO,PEDFINALIDADE,GRUPOCLI,GRUPOROTULOS,LOCALPED,REQUI,PEDFO,NOTAS,PEDID,PDPRD,PDSER,TBFIS,COMPOPROROT,REGRAPROMO,USUARIO,ACOPED

# -- Filtros para tabelas grandes/transacionais -----------------------------
SYNC_DATE_COLUMNS=CCORR:CCODATA,PAGAR:PAGDTVENCTO,RECEB:RECDTVENCTO,MOVIMENTACAO:DATA,REQUI:REQDATA,PEDFO:PEFDTBAIXA,NOTAS:NFDTEMIS,PEDID:PEDDTEMIS,ACOPED:APDATA
SYNC_DATE_FROM=2025-04-23
SYNC_RECENT_DAYS=3
SYNC_DATE_TABLES_ONLY=true

# -- Performance ------------------------------------------------------------
SYNC_FETCH_BATCH=1000
SYNC_INSERT_BATCH=500
SYNC_INTERVAL_SECONDS=300
SYNC_LOG_DIR=logs
